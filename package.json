{
  "name": "int-messager-desktop",
  "version": "1.0.0",
  "description": "Int Messager desktop app",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "server": "node server.js",
    "electron:dev": "concurrently \"node server.js\" \"cd client && npm run dev\" \"wait-on http://localhost:3001/api http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:pack": "npm run client:build && electron-builder --dir",
    "electron:dist": "npm run client:build && electron-builder"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.intmessager.desktop",
    "productName": "Int Messager",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "package.json",
      "client/dist/**/*",
      "uploads/**/*",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Int-Messager-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
